{
  "name": "billix-monorepo",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "build": "npm run build --workspace=client",
    "start": "node server/server.js",
    "dev": "concurrently \"npm run dev --workspace=client\" \"npm run start --workspace=server\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
